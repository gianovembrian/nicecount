APP_NAME=NiceCount
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_BASE_URL=http://localhost:8000
SESSION_SECRET_KEY=vehicle-count-local-secret
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/vehicle_count
AUTO_CREATE_TABLES=false
STORAGE_ROOT=storage
DEFAULT_MODEL_PATH=yolov8s.pt
DEFAULT_TRACKER_CONFIG=bytetrack.yaml
DEFAULT_CONFIDENCE=0.12
DEFAULT_IOU=0.45
DEFAULT_FRAME_STRIDE=1
DEFAULT_TARGET_ANALYSIS_FPS=15
DEFAULT_PREVIEW_FPS=6
DEFAULT_WORKING_MAX_WIDTH=1600
DEFAULT_PREVIEW_MAX_WIDTH=960
DEFAULT_PREVIEW_JPEG_QUALITY=70
DEFAULT_INFERENCE_IMGSZ=1152
DEFAULT_INFERENCE_DEVICE=auto
SAVE_ANNOTATED_VIDEO=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin123
BOOTSTRAP_ADMIN_FULL_NAME=Administrator
DEFAULT_SITE_CODE=DEFAULT
DEFAULT_SITE_NAME=Default Site
DEFAULT_SITE_DIRECTION_NORMAL_LABEL=Normal
DEFAULT_SITE_DIRECTION_OPPOSITE_LABEL=Opposite
DEFAULT_LINE_START_X=0.15
DEFAULT_LINE_START_Y=0.58
DEFAULT_LINE_END_X=0.85
DEFAULT_LINE_END_Y=0.58
